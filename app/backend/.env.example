# ═══════════════════════════════════════════════════════════════
# 新致远智慧消防平台 - 后端环境变量示例
# 复制为 .env 后填写真实值
# ═══════════════════════════════════════════════════════════════

# 服务配置
NODE_ENV=production
PORT=5003

# JWT 密钥（生产环境必须修改为随机长字符串，切勿使用默认值）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS 配置（生产环境填写前端域名，多个用逗号分隔）
CORS_ORIGIN=https://your-domain.com

# MySQL 数据库连接（fire_platform 为主库）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fire_platform
DB_PASSWORD=your-strong-password
DB_NAME=fire_platform
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock

# FSCN8001 协议数据库（建议统一为 fire_platform）
FSCN_DB_HOST=127.0.0.1
FSCN_DB_PORT=3306
FSCN_DB_USER=fire_platform
FSCN_DB_PASSWORD=your-strong-password
FSCN_DB_NAME=fire_platform

# Redis 缓存（可选）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# WVP-PRO 视频平台（可选）
WVP_BASE_URL=http://127.0.0.1:18080
WVP_USERNAME=admin
WVP_PASSWORD=admin
