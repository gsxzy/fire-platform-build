# ═══════════════════════════════════════════════════════════════
# 新致远智慧消防平台 - 前端环境变量示例
# 复制为 .env（开发）或 .env.production（生产）后使用
# ═══════════════════════════════════════════════════════════════

# 应用信息
VITE_APP_TITLE=新致远智慧消防远程监控中心
VITE_APP_VERSION=2.0.0

# API 基础路径（生产环境通常为空或 /api）
VITE_API_BASE=/api

# WebSocket 地址
VITE_WS_URL=ws://localhost:3000/ws

# MQTT Broker（如使用物联网直连）
VITE_MQTT_HOST=ws://localhost:9001

# 高德地图 Key（用于 GIS 地图模块）
VITE_AMAP_KEY=

# Mock 模式开关（开发可设为 true，生产必须 false）
VITE_USE_MOCK=false

# WVP-PRO 视频平台集成（前端直接调用模式，已废弃，改为后端代理）
# VITE_WVP_ENABLED 设为 true 时前端将调用后端 /api/video/* 接口
VITE_WVP_ENABLED=true

# 后端 WVP-PRO 配置（后端服务调用）
WVP_PRO_URL=http://localhost:18080
WVP_PRO_SECRET=your-secret-key
