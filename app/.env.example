# ═══════════════════════════════════════════════════════════════
# 新致远智慧消防平台 - 前端环境变量示例
# 复制为 .env（开发）或 .env.production（生产）后使用
# ═══════════════════════════════════════════════════════════════

# 应用信息
VITE_APP_TITLE=新致远智慧消防远程监控中心
VITE_APP_VERSION=2.0.0

# API 基础路径（生产环境通常为空或 /api）
VITE_API_BASE=/api

# WebSocket 地址
VITE_WS_URL=ws://localhost:3000/ws

# MQTT Broker（如使用物联网直连）
VITE_MQTT_HOST=ws://localhost:9001

# 高德地图 Key（用于 GIS 地图模块，控制台应用类型选「Web端(JS API)」）
VITE_AMAP_KEY=
# 安全密钥（securityJsCode），与 Key 配对使用；高德控制台「安全设置」中复制
VITE_AMAP_SECURITY_JS_CODE=

# Mock 模式开关（开发可设为 true，生产必须 false）
VITE_USE_MOCK=false

# Vite 开发服务器代理目标（填写后端 API 地址，默认 localhost）
VITE_DEV_PROXY_TARGET=http://localhost:5003

# WVP-PRO 视频平台集成（前端直接调用模式，已废弃，改为后端代理）
# VITE_WVP_ENABLED 设为 true 时前端将调用后端 /api/video/* 接口
VITE_WVP_ENABLED=true

# 二次验证密码（消控室敏感操作）
VITE_SECONDARY_VERIFY_PWD=

# WVP-PRO 视频平台登录凭据（前端直接调用 WVP 接口时使用）
VITE_WVP_USERNAME=admin
VITE_WVP_PASSWORD=
