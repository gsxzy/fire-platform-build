# 新致远智慧消防云平台 - 环境配置
NODE_ENV=production
PORT=3000

# MySQL数据库
DB_HOST=mysql
DB_PORT=3306
DB_NAME=fire_platform
DB_USER=fire_user
DB_PASSWORD=Fire_Pass_2024!
DB_POOL_MIN=5
DB_POOL_MAX=20

# JWT认证
JWT_SECRET=xzy_fire_platform_secret_key_2024_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Redis缓存
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT Broker (IoT设备接入)
MQTT_PORT=1883
MQTT_WS_PORT=9001

# 文件上传
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# 日志
LOG_LEVEL=info
LOG_DIR=./logs

# 邮件通知
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=智慧消防平台 <noreply@xzy.cn>

# 高德地图
AMAP_KEY=your_amap_key_here

# 超级管理员默认账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_PHONE=13800138000
