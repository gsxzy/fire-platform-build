# ═══════════════════════════════════════════════════════════════
# 新致远智慧消防云平台 - 环境变量示例
# 复制为 .env（开发）或 .env.production（生产）后使用
# ⚠️ 请勿提交包含真实密码的 .env 文件到版本控制
# ═══════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=5003

# MySQL数据库
# 如果使用 Unix Socket 连接（生产环境常见），配置 DB_SOCKET_PATH，忽略 DB_HOST/DB_PORT
# DB_SOCKET_PATH=/tmp/mysql.sock
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fire_platform
DB_USER=fire_user
# ⚠️ 必须修改：数据库密码，不能为空
DB_PASSWORD=
DB_POOL_MIN=5
DB_POOL_MAX=20

# 权限严格模式：设为 1 时，无 permissions 的用户将被拒绝写操作（默认兼容放行）
# PERMISSION_STRICT=0

# JWT认证
# ⚠️ 必须修改：生产环境请使用 openssl rand -base64 64 生成强密钥
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Redis缓存
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT Broker (IoT设备接入)
MQTT_PORT=1883
MQTT_WS_PORT=9001

# 文件上传
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads

# 日志
LOG_LEVEL=info
LOG_DIR=./logs

# 邮件通知
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=智慧消防平台 <noreply@xzy.cn>

# 高德地图
AMAP_KEY=your_amap_key_here

# 超级管理员默认账号（首次 seed 时使用）
ADMIN_USERNAME=admin
# ⚠️ 必须修改：管理员初始密码
ADMIN_PASSWORD=
ADMIN_PHONE=

# ═══════════════════════════════════════════════════════════════
# 协议服务器配置
# ═══════════════════════════════════════════════════════════════

# GB26875 用户信息传输装置 TCP 服务器
GB26875_PORT=5200
GB26875_HOST=0.0.0.0

# FSCN8001 传输装置 TCP 服务器（赋安私有帧，与 GB26875 共用 5200 端口，通过帧头区分）
FSCN8001_PORT=5200
FSCN8001_HOST=0.0.0.0

# 设备心跳检测周期（Cron 表达式，默认每分钟）
HEARTBEAT_CRON=* * * * *

# 心跳超时阈值（分钟）
HEARTBEAT_TIMEOUT_MINUTES=10

# ═══════════════════════════════════════════════════════════════
# 视频监控配置（ZLM + WVP-PRO）
# ═══════════════════════════════════════════════════════════════

# ZLMediaKit 流媒体服务器
ZLM_API_URL=http://localhost:8081
# ⚠️ 必须修改：ZLM Secret
ZLM_SECRET=
ZLM_PLAY_HOST=127.0.0.1

# 直连摄像头 RTSP 配置
CAM1_IP=127.0.0.1
CAM1_USER=admin
CAM1_PASS=
CAM2_IP=127.0.0.1
CAM2_USER=admin
CAM2_PASS=

# WVP-PRO GB28181 平台（配置后启用 WVP 模式，否则走 ZLM 直连）
WVP_PRO_URL=http://localhost:18080
WVP_PRO_USER=admin
WVP_PRO_SECRET=

# CORS 允许的来源（多个用逗号分隔）；不配置则反射请求 Origin（与旧版行为一致）
# 商用部署建议填写实际站点，例如：https://fire.example.com
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# 置于 Nginx 等反向代理之后时设为 1，以便限流与日志使用真实客户端 IP
# TRUST_PROXY=1
# 代理层数（默认 1）
# TRUST_PROXY_HOPS=1

# CTWing 天翼物联网 HTTP 推送（签名验证用，在 CTWing 平台「应用管理」中获取）
# ⚠️ 建议配置：未配置时跳过签名验证（不安全）
CTWING_API_KEY=

# 若为 1：CTWing 上报在「无匹配 fire_device」时仍可自动创建无 archive 的 fire_iot_device（旧版行为，易产生孤儿，不推荐）
# CTWING_ALLOW_ORPHAN_IOT=0

# 海康4G IoT 设备接入 API Key
# ⚠️ 必须修改：用于验证海康4G设备上报请求
HIKVISION_4G_API_KEY=

# ═══════════════════════════════════════════════════════════
# IoT 安全（生产环境必须配置）
# ═══════════════════════════════════════════════════════════
# IoT 接口 IP 白名单：CTWing / 海康4G 等公开推送接口的访问控制
# - 多个 IP 用逗号分隔
# - 留空表示不限制（⚠️ 生产环境强烈建议配置）
# - CTWing 平台 IP 可在「应用管理 → 推送设置」中查看
# - 海康4G 设备 IP 由运营商分配，通常为固定段
# IOT_IP_WHITELIST=
