# ═══════════════════════════════════════════════════════════════
# 新致远智慧消防云平台 - 三库分离环境变量示例
# 复制为 .env（开发）或 .env.production（生产）后使用
# ⚠️ 请勿提交包含真实密码的 .env 文件到版本控制
# ═══════════════════════════════════════════════════════════════
NODE_ENV=production
PORT=5003

# ═══════════════════════════════════════════════════════════════
# 1. PostgreSQL 业务主库（原 MySQL 已迁移）
# ═══════════════════════════════════════════════════════════════
# 如果使用 Unix Socket 连接（生产环境常见），配置 DB_SOCKET_PATH，忽略 DB_HOST/DB_PORT
# DB_SOCKET_PATH=/tmp/.s.PGSQL.5432
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=fire_platform
DB_USER=fire_platform
# ⚠️ 必须修改：数据库密码，不能为空
DB_PASSWORD=
DB_POOL_MIN=5
DB_POOL_MAX=20

# ═══════════════════════════════════════════════════════════════
# 2. Redis 缓存层
# ═══════════════════════════════════════════════════════════════
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# 3. TDengine 时序数据库（传感器遥测数据 + 原始报文日志）
# ═══════════════════════════════════════════════════════════════
TDENGINE_URL=http://127.0.0.1:6041
TDENGINE_DB=fire_platform_ts
TDENGINE_USER=root
TDENGINE_PASSWORD=taosdata

# ═══════════════════════════════════════════════════════════════
# 权限与认证
# ═══════════════════════════════════════════════════════════════
# 权限严格模式：设为 1 时，无 permissions 的用户将被拒绝写操作（默认兼容放行）
# PERMISSION_STRICT=0

# JWT认证
# ⚠️ 必须修改：生产环境请使用 openssl rand -base64 64 生成强密钥
JWT_SECRET=
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ═══════════════════════════════════════════════════════════════
# MQTT Broker (IoT设备接入)
# ═══════════════════════════════════════════════════════════════
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_PORT=1883
MQTT_WS_PORT=9001

# ═══════════════════════════════════════════════════════════════
# 文件上传与日志
# ═══════════════════════════════════════════════════════════════
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
LOG_LEVEL=info
LOG_DIR=./logs

# ═══════════════════════════════════════════════════════════════
# 邮件通知
# ═══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=智慧消防平台 <noreply@xzy.cn>

# ═══════════════════════════════════════════════════════════════
# 高德地图
# ═══════════════════════════════════════════════════════════════
AMAP_KEY=your_amap_key_here

# ═══════════════════════════════════════════════════════════════
# 超级管理员默认账号（首次 seed 时使用）
# ═══════════════════════════════════════════════════════════════
ADMIN_USERNAME=admin
# ⚠️ 必须修改：管理员初始密码
ADMIN_PASSWORD=
ADMIN_PHONE=

# ═══════════════════════════════════════════════════════════════
# 协议服务器配置
# ═══════════════════════════════════════════════════════════════
# GB26875 用户信息传输装置 TCP 服务器
GB26875_PORT=5200
GB26875_HOST=0.0.0.0

# FSCN8001 传输装置 TCP 服务器（赋安私有帧）
FSCN8001_PORT=5201
FSCN8001_HOST=0.0.0.0

# 智嵌 CANET 网关 TCP 服务器
CANET_PORT=1030
CANET_HOST=0.0.0.0

# 设备心跳检测周期（Cron 表达式，默认每分钟）
HEARTBEAT_CRON=* * * * *
# 心跳超时阈值（分钟）
HEARTBEAT_TIMEOUT_MINUTES=10

# ═══════════════════════════════════════════════════════════════
# 视频监控配置（ZLM + WVP-PRO）
# ═══════════════════════════════════════════════════════════════
# ZLMediaKit 流媒体服务器
ZLM_API_URL=http://localhost:8081
# ⚠️ 必须修改：ZLM Secret
ZLM_SECRET=
ZLM_PLAY_HOST=127.0.0.1

# 直连摄像头 RTSP 配置
CAM1_IP=127.0.0.1
CAM1_USER=admin
CAM1_PASS=
CAM2_IP=127.0.0.1
CAM2_USER=admin
CAM2_PASS=

# WVP-PRO GB28181 平台
WVP_PRO_URL=http://localhost:18080
WVP_PRO_USER=admin
WVP_PRO_SECRET=

# ═══════════════════════════════════════════════════════════════
# CORS 与安全
# ═══════════════════════════════════════════════════════════════
# CORS 允许的来源（多个用逗号分隔）
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# 置于 Nginx 等反向代理之后时设为 1
# TRUST_PROXY=1
# TRUST_PROXY_HOPS=1

# ═══════════════════════════════════════════════════════════════
# IoT 平台接入
# ═══════════════════════════════════════════════════════════════
# CTWing 天翼物联网 HTTP 推送（签名验证用）
# ⚠️ 建议配置：未配置时跳过签名验证（不安全）
CTWING_API_KEY=

# CTWing 上报在无匹配 fire_device 时仍可自动创建
# CTWING_ALLOW_ORPHAN_IOT=0

# 海康4G IoT 设备接入 API Key
HIKVISION_4G_API_KEY=

# IoT 接口 IP 白名单（生产环境强烈建议配置）
# IOT_IP_WHITELIST=
